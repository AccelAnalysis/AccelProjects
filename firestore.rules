rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAccelOrg(organizationId) {
      return organizationId == "org_accel_projects";
    }

    function isOrgMember(organizationId) {
      return isSignedIn()
        && isAccelOrg(organizationId)
        && exists(/databases/$(database)/documents/organizations/$(organizationId)/users/$(request.auth.uid));
    }

    function signedInUserRole(organizationId) {
      return get(/databases/$(database)/documents/organizations/$(organizationId)/users/$(request.auth.uid)).data.role;
    }

    function isAdmin(organizationId) {
      return isOrgMember(organizationId) && signedInUserRole(organizationId) == "admin";
    }

    function isInternalOrgMember(organizationId) {
      return isOrgMember(organizationId)
        && !(signedInUserRole(organizationId) in ["client"]);
    }

    function canWriteProjectData(organizationId) {
      return isOrgMember(organizationId)
        && signedInUserRole(organizationId) in ["admin", "project_manager"];
    }

    function isProjectManagerRole(organizationId) {
      return isOrgMember(organizationId)
        && signedInUserRole(organizationId) == "project_manager";
    }

    function isContributorRole(organizationId) {
      return isOrgMember(organizationId)
        && signedInUserRole(organizationId) == "contributor";
    }

    function projectData(organizationId, projectId) {
      return get(/databases/$(database)/documents/organizations/$(organizationId)/projects/$(projectId)).data;
    }

    function projectExists(organizationId, projectId) {
      return projectId is string
        && exists(/databases/$(database)/documents/organizations/$(organizationId)/projects/$(projectId));
    }

    function isProjectMemberByUserId(organizationId, projectId, userId) {
      return exists(/databases/$(database)/documents/organizations/$(organizationId)/projects/$(projectId)/members/$(userId))
        && get(/databases/$(database)/documents/organizations/$(organizationId)/projects/$(projectId)/members/$(userId)).data.userId == userId;
    }

    function isProjectOwnerManager(organizationId, projectId) {
      return isProjectManagerRole(organizationId)
        && projectData(organizationId, projectId).ownerId == request.auth.uid;
    }

    function isProjectLeadManager(organizationId, projectId) {
      return isProjectManagerRole(organizationId)
        && isProjectMemberByUserId(organizationId, projectId, request.auth.uid)
        && get(/databases/$(database)/documents/organizations/$(organizationId)/projects/$(projectId)/members/$(request.auth.uid)).data.role == "lead";
    }

    function canReadProject(organizationId, projectId) {
      return isSignedIn()
        && isAccelOrg(organizationId)
        && projectExists(organizationId, projectId)
        && (
          isAdmin(organizationId)
          || (
            isInternalOrgMember(organizationId)
            && (
              projectData(organizationId, projectId).ownerId == request.auth.uid
              || isProjectMemberByUserId(organizationId, projectId, request.auth.uid)
            )
          )
        );
    }

    function canListProject(organizationId) {
      return isSignedIn()
        && isAccelOrg(organizationId)
        && (
          isAdmin(organizationId)
          || (
            isInternalOrgMember(organizationId)
            && ("ownerId" in resource.data)
            && resource.data.ownerId is string
            && resource.data.ownerId == request.auth.uid
          )
        );
    }

    function canManageProjectSchedule(organizationId, projectId) {
      return isAdmin(organizationId) || isProjectOwnerManager(organizationId, projectId) || isProjectLeadManager(organizationId, projectId);
    }

    function canWriteProjectRevisionFields(organizationId, projectId) {
      return (canManageProjectSchedule(organizationId, projectId) || (isContributorRole(organizationId) && canReadProject(organizationId, projectId)))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "revision",
          "updatedAt",
          "lastStructuralChangeAt"
        ]);
    }

    function canCreateProjectVersion(organizationId, projectId) {
      return isOrgMember(organizationId)
        && request.resource.data.projectId == projectId
        && request.resource.data.actorId == request.auth.uid
        && (
          (request.resource.data.changeType == "project_file_updated" && canManageProjectSchedule(organizationId, projectId))
          || (request.resource.data.changeType != "project_file_updated" && canWriteProjectData(organizationId))
          || (request.resource.data.changeType == "task_updated" && isContributorRole(organizationId))
        );
    }

    function canCreateProjectSnapshot(organizationId, projectId) {
      return canManageProjectSchedule(organizationId, projectId)
        && request.resource.data.projectId == projectId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.snapshotType in ["manual_export", "revision_result"];
    }

    function canCreateUpdateManifest(organizationId, projectId, manifestId) {
      return canManageProjectSchedule(organizationId, projectId)
        && request.resource.data.id == manifestId
        && request.resource.data.projectId == projectId
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.uploadedFileHash == manifestId;
    }

    function canContributorUpdateAssignedTask(organizationId) {
      return isContributorRole(organizationId)
        && resource.data.assigneeId == request.auth.uid
        && request.resource.data.assigneeId == resource.data.assigneeId
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "priority",
          "startDate",
          "dueDate",
          "completedAt",
          "updatedAt"
        ]);
    }

    function isOwnBootstrapProfile(organizationId, userId) {
      return isSignedIn()
        && isAccelOrg(organizationId)
        && userId == request.auth.uid
        && request.resource.data.id == request.auth.uid
        && request.resource.data.organizationId == organizationId
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role == "viewer"
        && request.resource.data.avatarInitials is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.keys().hasOnly([
          "id",
          "organizationId",
          "email",
          "name",
          "role",
          "avatarInitials",
          "createdAt",
          "updatedAt",
          "notificationPreferences"
        ])
        && (!("notificationPreferences" in request.resource.data) || validNotificationPreferences(request.resource.data.notificationPreferences));
    }

    function validNotificationPreferences(preferences) {
      return preferences is map
        && preferences.keys().hasOnly([
          "taskAssignments",
          "dueDates",
          "risks",
          "projectMessages",
          "emailDelivery"
        ])
        && (!("taskAssignments" in preferences) || preferences.taskAssignments is bool)
        && (!("dueDates" in preferences) || preferences.dueDates is bool)
        && (!("risks" in preferences) || preferences.risks is bool)
        && (!("projectMessages" in preferences) || preferences.projectMessages is bool)
        && (!("emailDelivery" in preferences) || preferences.emailDelivery is bool);
    }

    function validUserProfileShape(organizationId, userId) {
      return request.resource.data.id == userId
        && request.resource.data.organizationId == organizationId
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role in ["admin", "project_manager", "contributor", "client", "viewer"]
        && request.resource.data.avatarInitials is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.keys().hasOnly([
          "id",
          "organizationId",
          "email",
          "name",
          "role",
          "avatarInitials",
          "createdAt",
          "updatedAt",
          "notificationPreferences"
        ])
        && (!("notificationPreferences" in request.resource.data) || validNotificationPreferences(request.resource.data.notificationPreferences));
    }

    function canUpdateOwnProfile(organizationId, userId) {
      return isSignedIn()
        && isAccelOrg(organizationId)
        && userId == request.auth.uid
        && validUserProfileShape(organizationId, userId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.organizationId == resource.data.organizationId
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "avatarInitials",
          "notificationPreferences",
          "updatedAt"
        ]);
    }

    function canAdminWriteUserProfile(organizationId, userId) {
      return isAdmin(organizationId)
        && validUserProfileShape(organizationId, userId);
    }

    function validOrganizationShape(organizationId) {
      return request.resource.data.id == organizationId
        && request.resource.data.name is string
        && request.resource.data.slug is string
        && request.resource.data.createdAt is string
        && request.resource.data.keys().hasOnly([
          "id",
          "name",
          "slug",
          "createdAt",
          "updatedAt"
        ])
        && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is string);
    }

    function canListOwnProjectMembership() {
      return isSignedIn()
        && signedInUserRole("org_accel_projects") != null
        && ("userId" in resource.data)
        && resource.data.userId == request.auth.uid;
    }

    match /organizations/{organizationId} {
      allow create: if isSignedIn() && isAccelOrg(organizationId) && validOrganizationShape(organizationId);
      allow get: if isSignedIn() && isAccelOrg(organizationId);
      allow list: if false;
      allow update: if isAdmin(organizationId)
        && validOrganizationShape(organizationId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["name", "updatedAt"]);
      allow delete: if false;

      match /users/{userId} {
        allow create: if isOwnBootstrapProfile(organizationId, userId) || canAdminWriteUserProfile(organizationId, userId);
        allow get: if (isSignedIn() && isAccelOrg(organizationId) && userId == request.auth.uid) || isInternalOrgMember(organizationId);
        allow list: if isInternalOrgMember(organizationId);
        allow update: if canUpdateOwnProfile(organizationId, userId) || canAdminWriteUserProfile(organizationId, userId);
        allow delete: if isAdmin(organizationId) && userId != request.auth.uid;
      }

      match /clients/{clientId} {
        allow read: if isInternalOrgMember(organizationId);
        allow create, update: if canWriteProjectData(organizationId);
        allow delete: if isAdmin(organizationId);
      }

      match /imports/{importId} {
        // MVP import manifests are written by the signed-in client after role checks in the app.
        // Firestore still limits manifest writes to admin and project_manager org members.
        allow read: if isInternalOrgMember(organizationId);
        allow create, update: if canWriteProjectData(organizationId);
        allow delete: if false;
      }

      match /projects/{projectId} {
        allow get: if canReadProject(organizationId, projectId);
        allow list: if canListProject(organizationId);
        allow create: if canWriteProjectData(organizationId);
        allow update: if canManageProjectSchedule(organizationId, projectId)
          || canWriteProjectRevisionFields(organizationId, projectId);
        allow delete: if isAdmin(organizationId);

        match /members/{memberId} {
          allow read: if canReadProject(organizationId, projectId)
            || (isSignedIn() && resource.data.userId == request.auth.uid);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /phases/{phaseId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /tasks/{taskId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow delete: if canManageProjectSchedule(organizationId, projectId);
          allow update: if canManageProjectSchedule(organizationId, projectId)
            || canContributorUpdateAssignedTask(organizationId);

          match /comments/{commentId} {
            allow read: if canReadProject(organizationId, projectId);
            allow write: if canReadProject(organizationId, projectId);
          }
        }

        match /taskDependencies/{dependencyId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /risks/{riskId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /documents/{documentId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /metrics/{metricId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /milestones/{milestoneId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if canManageProjectSchedule(organizationId, projectId);
        }

        match /activityEvents/{eventId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canWriteProjectData(organizationId);
          allow update, delete: if false;
        }

        match /versions/{versionId} {
          allow read: if canReadProject(organizationId, projectId);
          allow create: if canCreateProjectVersion(organizationId, projectId);
          allow update, delete: if false;
        }

        match /exportSnapshots/{snapshotId} {
          allow read: if canManageProjectSchedule(organizationId, projectId);
          allow create: if canCreateProjectSnapshot(organizationId, projectId);
          allow update, delete: if false;
        }

        match /updateManifests/{manifestId} {
          allow read: if canManageProjectSchedule(organizationId, projectId);
          allow create: if canCreateUpdateManifest(organizationId, projectId, manifestId);
          allow update, delete: if false;
        }
      }
    }

    match /{membershipPath=**}/members/{memberId} {
      allow list: if canListOwnProjectMembership();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
