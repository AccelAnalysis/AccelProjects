rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /organizations/org_accel_projects/{document=**} {
      allow read, write: if request.auth != null;
      // TODO: Restrict reads and writes by organization membership records.
      // TODO: Enforce project role permissions for tasks, risks, documents, and settings.
      // TODO: Separate client-safe access from internal project operations data.
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
